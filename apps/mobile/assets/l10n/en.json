  "accessibility_title": "Accessibility Statement",
  "accessibility_intro_title": "Commitment to Accessibility",
  "accessibility_intro_text": "Metzudat HaLikud is committed to ensuring the accessibility of the application to all users, including people with disabilities, in accordance with the Equal Rights for Persons with Disabilities Law (1998), Service Accessibility Regulations (2013), and Israeli Standard IS 5568.",
  "accessibility_legal_title": "Legal Framework",
  "accessibility_legal_text": "This accessibility statement is written in accordance with:\n• Equal Rights for Persons with Disabilities Law, 1998\n• Equal Rights for Persons with Disabilities (Service Accessibility) Regulations, 2013, Section 35\n• Israeli Standard IS 5568 (based on WCAG 2.0 Level AA)\n• Web Content Accessibility Guidelines (WCAG) 2.1 Level AA",
  "accessibility_features_title": "Accessibility Accommodations",
  "accessibility_feature_1": "Full screen reader support (VoiceOver on iOS, TalkBack on Android) with semantic labels for all elements",
  "accessibility_feature_2": "Color contrast ratios meeting WCAG 2.1 AA (4.5:1 for normal text, 3:1 for large text)",
  "accessibility_feature_3": "Font enlargement support up to 2x without loss of content or functionality",
  "accessibility_feature_4": "Minimum touch target size of 44x44 points per Apple and Google guidelines",
  "accessibility_feature_5": "Full right-to-left (RTL) direction support for Hebrew",
  "accessibility_feature_6": "Full keyboard navigation via external keyboard",
  "accessibility_feature_7": "Respects device 'Reduce Motion' setting",
  "accessibility_feature_8": "Alternative text (Alt) for all content images",
  "accessibility_coordinator_title": "Accessibility Coordinator",
  "accessibility_coordinator_text": "Name: Accessibility Coordinator\nPhone: 02-XXX-XXXX\nEmail: accessibility@likud.org.il\nAddress: Metzudat Ze'ev, 38 King George St., Tel Aviv",
  "accessibility_report_title": "Report an Accessibility Issue",
  "accessibility_report_text": "If you encounter an accessibility issue in the app, we'd love to hear from you:\n• Email: accessibility@likud.org.il\n• Phone: 02-XXX-XXXX\n• Via the 'Contact Us' form in the app",
  "accessibility_response_title": "Response Time",
  "accessibility_response_text": "We commit to addressing every accessibility inquiry within 14 business days of receipt. For urgent matters, please call the accessibility coordinator directly.",
  "accessibility_audit_title": "Last Accessibility Audit",
  "accessibility_audit_text": "The most recent accessibility audit of the application was conducted in accordance with IS 5568 and WCAG 2.1 AA guidelines.",
  "accessibility_known_issues_title": "Known Limitations",
  "accessibility_known_issues_text": "We are aware of the following limitations and are working to resolve them:\n• Embedded videos may not include captions in all cases\n• User-generated content (comments) may not be fully accessible",
  "accessibility_complaint_title": "Filing a Complaint",
  "accessibility_complaint_text": "If your inquiry to the accessibility coordinator was not adequately addressed, you may file a complaint with the Commission for Equal Rights of Persons with Disabilities:\n• Phone: *6763\n• Website: https://www.gov.il/he/departments/equal_rights_commission",
  "accessibility_updated_title": "Last Updated",
  "accessibility_updated_text": "This accessibility statement was last updated: March 2026.",
