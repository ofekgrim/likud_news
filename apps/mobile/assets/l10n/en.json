  "privacy_title": "Privacy Policy",
  "privacy_intro_title": "Introduction",
  "privacy_intro_text": "Metzudat HaLikud (\"the Application\") respects user privacy. This privacy policy explains how we collect, use, and protect your information.",
  "privacy_collection_title": "Information Collection",
  "privacy_collection_item_1": "Anonymous device identifier for saving favorites and reading history",
  "privacy_collection_item_2": "Push notification token for sending updates",
  "privacy_collection_item_3": "Anonymous usage data for service improvement",
  "privacy_usage_title": "Use of Information",
  "privacy_usage_text": "The collected information is used solely for:\n• Operating app features (favorites, history)\n• Sending news notifications\n• Improving user experience\n• Anonymous statistical analysis",
  "privacy_sharing_title": "Information Sharing",
  "privacy_sharing_text": "We do not sell, trade, or transfer your personal information to third parties, except for service providers required to operate the application.",
  "privacy_security_title": "Information Security",
  "privacy_security_text": "We take reasonable security measures to protect your information, including communication encryption (SSL/TLS) and secure storage.",
  "privacy_contact_title": "Contact",
  "privacy_contact_text": "For questions about the privacy policy, please contact us:\nEmail: privacy@likud.org.il",
  "privacy_updated_title": "Last Updated",
  "privacy_updated_text": "This privacy policy was last updated in February 2026.",
